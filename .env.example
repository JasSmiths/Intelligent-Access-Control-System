# Copy this file to .env before running docker compose.

COMPOSE_PROJECT_NAME=iacs

BACKEND_PORT=8088
FRONTEND_PORT=8089
BACKEND_BUILD_TARGET=development
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379

POSTGRES_DB=iacs
POSTGRES_USER=iacs
POSTGRES_PASSWORD=iacs_dev_password

IACS_ENVIRONMENT=development
IACS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8088
IACS_TRUSTED_HOSTS=*
IACS_TRUSTED_PROXY_IPS=

# LAN example: http://192.168.1.50:8088
# Nginx Proxy Manager example: https://access.example.com
IACS_PUBLIC_BASE_URL=

# Postgres and Redis bind to loopback by default. To expose them on a LAN, set
# POSTGRES_BIND_HOST/REDIS_BIND_HOST deliberately and replace all dev passwords.

# Only set this if reverse proxying under a subpath such as /access.
IACS_ROOT_PATH=
IACS_AUTO_CREATE_SCHEMA=true
# Runs the old transitional bootstrap DDL after Alembic for pre-migration dev DBs.
IACS_LEGACY_SCHEMA_BOOTSTRAP=false
IACS_SEED_DEMO_DATA=false
IACS_AUTH_SECRET_FILE=/app/data/auth-secret.key
# Optional advanced override. When set, UI rotation is unavailable.
# IACS_AUTH_SECRET_KEY=replace-with-a-long-random-secret

# Dynamic settings moved to the database and are managed in the web UI:
# app name, log level, timezone, auth cookie options, LPR tuning,
# Home Assistant, Apprise, and LLM provider/API settings.
